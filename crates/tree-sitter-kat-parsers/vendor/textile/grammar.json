{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "textile",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "heading"
          },
          {
            "type": "SYMBOL",
            "name": "code_block"
          },
          {
            "type": "SYMBOL",
            "name": "list_item"
          },
          {
            "type": "SYMBOL",
            "name": "paragraph"
          },
          {
            "type": "SYMBOL",
            "name": "_blank_line"
          }
        ]
      }
    },
    "heading": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "h1."
              },
              {
                "type": "STRING",
                "value": "h2."
              },
              {
                "type": "STRING",
                "value": "h3."
              },
              {
                "type": "STRING",
                "value": "h4."
              },
              {
                "type": "STRING",
                "value": "h5."
              },
              {
                "type": "STRING",
                "value": "h6."
              }
            ]
          }
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]+"
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "code_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "bc."
              },
              {
                "type": "STRING",
                "value": "pre."
              }
            ]
          }
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]+"
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "list_item": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "\\*+"
              },
              {
                "type": "PATTERN",
                "value": "#+"
              }
            ]
          }
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]+"
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "paragraph": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[^\\n]+"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "_blank_line": {
      "type": "SYMBOL",
      "name": "_newline"
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}