{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "git_rebase",
  "rules": {
    "source": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "instruction_line"
          },
          {
            "type": "SYMBOL",
            "name": "comment_line"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          }
        ]
      }
    },
    "instruction_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_space"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "command"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_space"
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "SYMBOL",
                      "name": "commit"
                    },
                    {
                      "type": "SYMBOL",
                      "name": "label"
                    }
                  ]
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_space"
                },
                {
                  "type": "SYMBOL",
                  "name": "subject"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_space"
                },
                {
                  "type": "SYMBOL",
                  "name": "comment"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "comment_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_space"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "command": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "pick"
        },
        {
          "type": "STRING",
          "value": "p"
        },
        {
          "type": "STRING",
          "value": "reword"
        },
        {
          "type": "STRING",
          "value": "r"
        },
        {
          "type": "STRING",
          "value": "edit"
        },
        {
          "type": "STRING",
          "value": "e"
        },
        {
          "type": "STRING",
          "value": "squash"
        },
        {
          "type": "STRING",
          "value": "s"
        },
        {
          "type": "STRING",
          "value": "fixup"
        },
        {
          "type": "STRING",
          "value": "f"
        },
        {
          "type": "STRING",
          "value": "exec"
        },
        {
          "type": "STRING",
          "value": "x"
        },
        {
          "type": "STRING",
          "value": "break"
        },
        {
          "type": "STRING",
          "value": "b"
        },
        {
          "type": "STRING",
          "value": "drop"
        },
        {
          "type": "STRING",
          "value": "d"
        },
        {
          "type": "STRING",
          "value": "label"
        },
        {
          "type": "STRING",
          "value": "l"
        },
        {
          "type": "STRING",
          "value": "reset"
        },
        {
          "type": "STRING",
          "value": "t"
        },
        {
          "type": "STRING",
          "value": "merge"
        },
        {
          "type": "STRING",
          "value": "m"
        },
        {
          "type": "STRING",
          "value": "update-ref"
        },
        {
          "type": "STRING",
          "value": "u"
        }
      ]
    },
    "commit": {
      "type": "PATTERN",
      "value": "[0-9a-fA-F]{4,40}"
    },
    "label": {
      "type": "PATTERN",
      "value": "[^\\s#]+"
    },
    "subject": {
      "type": "PATTERN",
      "value": "[^\\n#]+"
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        ]
      }
    },
    "_space": {
      "type": "PATTERN",
      "value": "[ \\t]+"
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}