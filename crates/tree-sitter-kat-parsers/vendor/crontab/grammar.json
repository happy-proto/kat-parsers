{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "crontab",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "cron_job"
          },
          {
            "type": "SYMBOL",
            "name": "special_job"
          },
          {
            "type": "SYMBOL",
            "name": "environment_variable"
          },
          {
            "type": "SYMBOL",
            "name": "comment"
          },
          {
            "type": "SYMBOL",
            "name": "_blank_line"
          }
        ]
      }
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_inline_whitespace"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "PATTERN",
          "value": "[^\\n]*"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "_blank_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_inline_whitespace"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "environment_variable": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_inline_whitespace"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_inline_whitespace"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "special_job": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "special",
          "content": {
            "type": "SYMBOL",
            "name": "special_time"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_whitespace"
        },
        {
          "type": "FIELD",
          "name": "command",
          "content": {
            "type": "SYMBOL",
            "name": "command"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "special_time": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "@reboot"
        },
        {
          "type": "STRING",
          "value": "@yearly"
        },
        {
          "type": "STRING",
          "value": "@annually"
        },
        {
          "type": "STRING",
          "value": "@monthly"
        },
        {
          "type": "STRING",
          "value": "@weekly"
        },
        {
          "type": "STRING",
          "value": "@daily"
        },
        {
          "type": "STRING",
          "value": "@midnight"
        },
        {
          "type": "STRING",
          "value": "@hourly"
        }
      ]
    },
    "cron_job": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "minute",
          "content": {
            "type": "SYMBOL",
            "name": "field"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_whitespace"
        },
        {
          "type": "FIELD",
          "name": "hour",
          "content": {
            "type": "SYMBOL",
            "name": "field"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_whitespace"
        },
        {
          "type": "FIELD",
          "name": "day_of_month",
          "content": {
            "type": "SYMBOL",
            "name": "field"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_whitespace"
        },
        {
          "type": "FIELD",
          "name": "month",
          "content": {
            "type": "SYMBOL",
            "name": "field"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_whitespace"
        },
        {
          "type": "FIELD",
          "name": "day_of_week",
          "content": {
            "type": "SYMBOL",
            "name": "field"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_whitespace"
        },
        {
          "type": "FIELD",
          "name": "command",
          "content": {
            "type": "SYMBOL",
            "name": "command"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "field": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_value"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "_value"
              }
            ]
          }
        }
      ]
    },
    "_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "step"
        },
        {
          "type": "SYMBOL",
          "name": "asterisk"
        },
        {
          "type": "SYMBOL",
          "name": "range"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        }
      ]
    },
    "range": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "STRING",
          "value": "-"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        }
      ]
    },
    "step": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "range"
            },
            {
              "type": "SYMBOL",
              "name": "asterisk"
            },
            {
              "type": "SYMBOL",
              "name": "number"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "/"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        }
      ]
    },
    "asterisk": {
      "type": "STRING",
      "value": "*"
    },
    "number": {
      "type": "PATTERN",
      "value": "\\d+"
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "command": {
      "type": "PATTERN",
      "value": "[^\\n]*"
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "_whitespace": {
      "type": "PATTERN",
      "value": "[ \\t]+"
    },
    "_inline_whitespace": {
      "type": "PATTERN",
      "value": "[ \\t]+"
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}