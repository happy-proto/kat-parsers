{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "debsources",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "entry"
          },
          {
            "type": "SYMBOL",
            "name": "comment"
          },
          {
            "type": "SYMBOL",
            "name": "_blank_line"
          }
        ]
      }
    },
    "entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "kind",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "deb"
              },
              {
                "type": "STRING",
                "value": "deb-src"
              }
            ]
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_gap"
                },
                {
                  "type": "FIELD",
                  "name": "options",
                  "content": {
                    "type": "SYMBOL",
                    "name": "options_block"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_gap"
        },
        {
          "type": "FIELD",
          "name": "uri",
          "content": {
            "type": "SYMBOL",
            "name": "uri"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_gap"
        },
        {
          "type": "FIELD",
          "name": "suite",
          "content": {
            "type": "SYMBOL",
            "name": "suite"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_gap"
              },
              {
                "type": "FIELD",
                "name": "component",
                "content": {
                  "type": "SYMBOL",
                  "name": "component"
                }
              }
            ]
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "options_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "FIELD",
                "name": "option",
                "content": {
                  "type": "SYMBOL",
                  "name": "option"
                }
              },
              {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "_gap"
                  },
                  {
                    "type": "BLANK"
                  }
                ]
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "option": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "option_name"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "option_value"
          }
        }
      ]
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "PATTERN",
          "value": "[^\\n]*"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "option_name": {
      "type": "PATTERN",
      "value": "[A-Za-z0-9-]+"
    },
    "option_value": {
      "type": "PATTERN",
      "value": "[^\\]\\s]+"
    },
    "uri": {
      "type": "PATTERN",
      "value": "[A-Za-z][A-Za-z0-9+.-]*:\\/\\/[^\\s]+"
    },
    "suite": {
      "type": "PATTERN",
      "value": "[^\\s\\[]+"
    },
    "component": {
      "type": "PATTERN",
      "value": "[^\\s\\[]+"
    },
    "_gap": {
      "type": "PATTERN",
      "value": "[ \\t]+"
    },
    "_blank_line": {
      "type": "SYMBOL",
      "name": "_newline"
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[\\t ]+"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}