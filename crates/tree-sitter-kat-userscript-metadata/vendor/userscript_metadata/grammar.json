{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "userscript_metadata",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "start_marker"
          },
          {
            "type": "SYMBOL",
            "name": "end_marker"
          },
          {
            "type": "SYMBOL",
            "name": "entry"
          },
          {
            "type": "SYMBOL",
            "name": "comment_line"
          }
        ]
      }
    },
    "start_marker": {
      "type": "PREC",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "prefix",
            "content": {
              "type": "SYMBOL",
              "name": "comment_prefix"
            }
          },
          {
            "type": "FIELD",
            "name": "marker",
            "content": {
              "type": "SYMBOL",
              "name": "start_delimiter"
            }
          }
        ]
      }
    },
    "end_marker": {
      "type": "PREC",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "prefix",
            "content": {
              "type": "SYMBOL",
              "name": "comment_prefix"
            }
          },
          {
            "type": "FIELD",
            "name": "marker",
            "content": {
              "type": "SYMBOL",
              "name": "end_delimiter"
            }
          }
        ]
      }
    },
    "entry": {
      "type": "PREC",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "prefix",
            "content": {
              "type": "SYMBOL",
              "name": "comment_prefix"
            }
          },
          {
            "type": "FIELD",
            "name": "key",
            "content": {
              "type": "SYMBOL",
              "name": "metadata_key"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "value",
                "content": {
                  "type": "SYMBOL",
                  "name": "metadata_value"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "comment_line": {
      "type": "PREC",
      "value": -1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "prefix",
            "content": {
              "type": "SYMBOL",
              "name": "comment_prefix"
            }
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "url"
                },
                {
                  "type": "SYMBOL",
                  "name": "metadata_token"
                }
              ]
            }
          }
        ]
      }
    },
    "comment_prefix": {
      "type": "STRING",
      "value": "//"
    },
    "start_delimiter": {
      "type": "STRING",
      "value": "==UserScript=="
    },
    "end_delimiter": {
      "type": "STRING",
      "value": "==/UserScript=="
    },
    "metadata_key": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "@"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "key_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "locale",
              "content": {
                "type": "SYMBOL",
                "name": "locale_suffix"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "key_name": {
      "type": "PATTERN",
      "value": "[A-Za-z][A-Za-z0-9-]*"
    },
    "locale_suffix": {
      "type": "PATTERN",
      "value": ":[A-Za-z0-9_-]+"
    },
    "metadata_value": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "url"
          },
          {
            "type": "SYMBOL",
            "name": "metadata_token"
          }
        ]
      }
    },
    "url": {
      "type": "PATTERN",
      "value": "[A-Za-z][A-Za-z0-9+.-]*:\\/\\/[^\\s]+"
    },
    "metadata_token": {
      "type": "PATTERN",
      "value": "[^@\\s][^\\s]*"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\r\\n]+"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}