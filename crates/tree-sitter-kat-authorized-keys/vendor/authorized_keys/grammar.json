{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "authorized_keys",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "entry"
          },
          {
            "type": "SYMBOL",
            "name": "comment_line"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "comment_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment_text"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "\n"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "options",
              "content": {
                "type": "SYMBOL",
                "name": "option_list"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "key_type",
          "content": {
            "type": "SYMBOL",
            "name": "key_type"
          }
        },
        {
          "type": "FIELD",
          "name": "key_blob",
          "content": {
            "type": "SYMBOL",
            "name": "key_blob"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "comment",
              "content": {
                "type": "SYMBOL",
                "name": "entry_comment"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "\n"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "option_list": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "option"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "option"
              }
            ]
          }
        }
      ]
    },
    "option": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "FIELD",
              "name": "name",
              "content": {
                "type": "SYMBOL",
                "name": "option_name"
              }
            },
            {
              "type": "STRING",
              "value": "="
            },
            {
              "type": "FIELD",
              "name": "value",
              "content": {
                "type": "SYMBOL",
                "name": "option_value"
              }
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "option_name"
          }
        }
      ]
    },
    "option_name": {
      "type": "PATTERN",
      "value": "[A-Za-z][A-Za-z0-9-]*"
    },
    "option_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "quoted_value"
        },
        {
          "type": "SYMBOL",
          "name": "bare_value"
        }
      ]
    },
    "quoted_value": {
      "type": "PATTERN",
      "value": "\"([^\"\\\\]|\\\\.)*\""
    },
    "bare_value": {
      "type": "PATTERN",
      "value": "[^,\\s#]+"
    },
    "key_type": {
      "type": "PATTERN",
      "value": "[A-Za-z0-9][A-Za-z0-9@._+-]*"
    },
    "key_blob": {
      "type": "PATTERN",
      "value": "[A-Za-z0-9+/=]+"
    },
    "entry_comment": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    },
    "comment_text": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\r]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}