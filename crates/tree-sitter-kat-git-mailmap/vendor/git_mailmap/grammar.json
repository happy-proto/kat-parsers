{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "git_mailmap",
  "rules": {
    "source": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "entry_line"
          },
          {
            "type": "SYMBOL",
            "name": "comment_line"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          }
        ]
      }
    },
    "entry_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "canonical",
          "content": {
            "type": "SYMBOL",
            "name": "mapping"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_space"
                },
                {
                  "type": "FIELD",
                  "name": "alias",
                  "content": {
                    "type": "SYMBOL",
                    "name": "mapping"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_space"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_line_ending"
        }
      ]
    },
    "mapping": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "FIELD",
                  "name": "name",
                  "content": {
                    "type": "SYMBOL",
                    "name": "person_name"
                  }
                },
                {
                  "type": "SYMBOL",
                  "name": "_space"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "email",
          "content": {
            "type": "SYMBOL",
            "name": "email"
          }
        }
      ]
    },
    "comment_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "_line_ending"
        }
      ]
    },
    "person_name": {
      "type": "PATTERN",
      "value": "(?:[^\\s<#][^<\\n]*[^\\s<]|[^\\s<#])"
    },
    "email": {
      "type": "PATTERN",
      "value": "<[^>\\n]+>"
    },
    "comment": {
      "type": "PATTERN",
      "value": "#[^\\n]*"
    },
    "_space": {
      "type": "PATTERN",
      "value": "[ \\t]+"
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "_eof": {
      "type": "STRING",
      "value": "\u0000"
    },
    "_line_ending": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_newline"
        },
        {
          "type": "SYMBOL",
          "name": "_eof"
        }
      ]
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}