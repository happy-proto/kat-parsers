{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "git_link",
  "rules": {
    "source": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "directive_line"
          },
          {
            "type": "SYMBOL",
            "name": "comment_line"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          }
        ]
      }
    },
    "directive_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "key",
          "content": {
            "type": "SYMBOL",
            "name": "key"
          }
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_space"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "path"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_line_ending"
        }
      ]
    },
    "comment_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "_line_ending"
        }
      ]
    },
    "key": {
      "type": "PATTERN",
      "value": "[A-Za-z][A-Za-z-]*"
    },
    "path": {
      "type": "PATTERN",
      "value": "[^\\s\\r\\n#][^\\r\\n#]*"
    },
    "comment": {
      "type": "PATTERN",
      "value": "#[^\\n]*"
    },
    "_space": {
      "type": "PATTERN",
      "value": "[ \\t]+"
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "_eof": {
      "type": "STRING",
      "value": "\u0000"
    },
    "_line_ending": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_newline"
        },
        {
          "type": "SYMBOL",
          "name": "_eof"
        }
      ]
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}